generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PLANNER
  VIEWER
}

enum RiskType {
  STOCKOUT
  EXCESS
  SUPPLIER
}

enum Severity {
  CRITICAL
  WARNING
  LOW
}

enum RiskStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum AlertChannel {
  EMAIL
  SLACK
  DASHBOARD
}

enum SupplyStatus {
  PLANNED
  IN_TRANSIT
  DELIVERED
  DELAYED
  CANCELLED
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          UserRole  @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  auditLogs     AuditLog[]
  alerts        Alert[]
}

model Material {
  id            String    @id @default(cuid())
  materialId    String    @unique
  description   String
  productFamily String
  unitOfMeasure String    @default("EA")
  createdAt     DateTime  @default(now())
  inventory     Inventory[]
  demand        Demand[]
  supply        Supply[]
  risks         Risk[]
}

model Location {
  id            String    @id @default(cuid())
  locationId    String    @unique
  name          String
  warehouseType String
  region        String
  country       String    @default("")
  createdAt     DateTime  @default(now())
  inventory     Inventory[]
  demand        Demand[]
  supply        Supply[]
  risks         Risk[]
}

model Supplier {
  id              String    @id @default(cuid())
  supplierId      String    @unique
  name            String
  reliabilityScore Float    @default(0.95)
  country         String
  leadTimeDays    Int       @default(14)
  riskLevel       Severity  @default(LOW)
  createdAt       DateTime  @default(now())
  supply          Supply[]
  risks           Risk[]
}

model Inventory {
  id            String    @id @default(cuid())
  material      Material  @relation(fields: [materialId], references: [materialId])
  materialId    String
  location      Location  @relation(fields: [locationId], references: [locationId])
  locationId    String
  onHandQty     Float
  availableQty  Float
  safetyStock   Float     @default(0)
  reorderPoint  Float     @default(0)
  maxStock      Float     @default(0)
  updatedAt     DateTime  @updatedAt

  @@unique([materialId, locationId])
}

model Demand {
  id            String    @id @default(cuid())
  material      Material  @relation(fields: [materialId], references: [materialId])
  materialId    String
  location      Location  @relation(fields: [locationId], references: [locationId])
  locationId    String
  demandQty     Float
  demandDate    DateTime
  demandType    String    @default("FORECAST")
  createdAt     DateTime  @default(now())
}

model Supply {
  id            String       @id @default(cuid())
  supplyId      String       @unique
  material      Material     @relation(fields: [materialId], references: [materialId])
  materialId    String
  supplier      Supplier     @relation(fields: [supplierId], references: [supplierId])
  supplierId    String
  location      Location     @relation(fields: [locationId], references: [locationId])
  locationId    String
  supplyQty     Float
  deliveryDate  DateTime
  status        SupplyStatus @default(PLANNED)
  createdAt     DateTime     @default(now())
}

model Risk {
  id              String     @id @default(cuid())
  material        Material?  @relation(fields: [materialId], references: [materialId])
  materialId      String?
  location        Location?  @relation(fields: [locationId], references: [locationId])
  locationId      String?
  supplier        Supplier?  @relation(fields: [supplierId], references: [supplierId])
  supplierId      String?
  riskType        RiskType
  severity        Severity
  confidence      Float      @default(0.8)
  description     String
  recommendation  String
  aiExplanation   String?    @db.Text
  status          RiskStatus @default(OPEN)
  projectedImpact String?
  detectedAt      DateTime   @default(now())
  resolvedAt      DateTime?
  alerts          Alert[]
}

model AuditLog {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  action      String
  entityType  String
  entityId    String
  details     String?  @db.Text
  createdAt   DateTime @default(now())
}

model Alert {
  id           String       @id @default(cuid())
  risk         Risk         @relation(fields: [riskId], references: [id])
  riskId       String
  user         User         @relation(fields: [userId], references: [id])
  userId       String
  channel      AlertChannel
  message      String
  sentAt       DateTime     @default(now())
  acknowledged Boolean      @default(false)
}
